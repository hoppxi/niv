(include "./src/widgets/wallpaper/selector.yuck")
(defwidget main-wallpaper []
  (image
    :class "main-wallpaper"
    :style "background-image: url('${WALLPAPER}')"
    :halign "fill"
    :valign "fill"
    :height 768
    :width 1366
  )
)

(defwindow wallpaper
  :focusable false
  :stacking "bg"
  :windowtype "normal"
  :wm-ignore true
  :geometry (geometry
    :x 0
    :y 0
    :width "100%"
    :height "105%"
    :anchor "center center"
  )
  :monitor 0
  (main-wallpaper)
)

